# 1. 自动检测文本文件，并进行换行符规范化
* text=auto

# 2. 源代码文件：强制使用 LF（方便跨平台协作）
*.c text eol=lf
*.h text eol=lf
*.s text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.inc text eol=lf

# 3. 汇编文件、链接脚本
*.s text eol=lf
*.ld text eol=lf
*.scat text eol=lf

# 4. Keil 工程核心文件：二进制，禁止转换
*.uvprojx binary
*.uvoptx binary
*.uvmpw binary
*.uvgui.* binary
*.uvguix.* binary
*.uvprojx.* binary
*.uvoptx.* binary

# 5. Keil 生成的其他中间文件（二进制，禁止转换）
*.o binary
*.d binary
*.crf binary
*.dep binary
*.lnp binary
*.depend binary
*.map binary
*.htm binary
*.hex binary
*.bin binary

# 6. 其他可能丢失格式的文件
*.jpg binary
*.png binary
*.bmp binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary

# 7. 编译器输出文件（二进制，禁止转换）
*.axf binary
*.elf binary